# ============================================
# ISO 27001 PoC — Environment Variables
# ============================================

# ── Server-side (Vercel Functions) ──
# These are NEVER exposed to the browser.
# Add these in Vercel Dashboard → Settings → Environment Variables

# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model (optional, defaults to gemini-2.0-flash-lite)
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── Client-side (optional) ──
# Set to "mock" to force offline mode (no API calls)
# VITE_AI_PROVIDER=mock

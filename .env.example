# ============================================
# ISO 27001 PoC — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================

# AI Provider: "claude" | "gemini" | "mock"
# Set to "mock" to use built-in offline responses (no API key needed)
VITE_AI_PROVIDER=mock

# Anthropic Claude API Key (if VITE_AI_PROVIDER=claude)
# Get yours at: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=

# Google Gemini API Key (if VITE_AI_PROVIDER=gemini)
# Get yours at: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=
